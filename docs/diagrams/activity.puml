@startuml
title LongConspectWriter - CLI activity diagram

skinparam shadowing false

start
:Load .env and configure logger;
:Parse CLI arguments;
:Load default YAML configs;
:Create LongConspectPipeline;

if (action == global_clustering?) then (yes)
  :Read global_plan_path;
  :Read local_clusters_path;
  if (both files exist?) then (yes)
    :Call _call_global_clustering();
  else (no)
    :Log critical validation error;
    stop
  endif
else (no)
  :Read path_to_file;
  if (input file exists?) then (yes)
    if (action == all?) then (yes)
      :Run full pipeline;
      :STT -> Drafter -> Clustering -> Synthesizer -> Markdown export;
    elseif (action == stt?) then (yes)
      :Call _call_stt();
    elseif (action == drafter?) then (yes)
      :Call _call_drafter();
    elseif (action == local_clustering?) then (yes)
      :Call _call_local_clustering();
    elseif (action == local_planner?) then (yes)
      :Call _call_local_planner();
    elseif (action == global_planner?) then (yes)
      :Call _call_global_planner();
    elseif (action == planner?) then (yes)
      :Call _call_planner();
    elseif (action == clustering?) then (yes)
      :Call _call_clustering();
    elseif (action == synthesizer?) then (yes)
      :Call _call_synthesizer();
    endif
  else (no)
    :Log critical validation error;
    stop
  endif
endif

if (output_path is not empty?) then (yes)
  :Log "work completed";
else (no)
  :Log critical output_path error;
endif

stop
@enduml
